	filter { func;
		result = []
		for values
			if func(it)
				result.push(it)
			end
		end
		result
	}

	reduce { init, func;
		accumulator = init
		for values
			accumulator = func(accumulator, it)
		end
		accumulator
	}

	each { func;
		for values
			func(it)
		end
	}
