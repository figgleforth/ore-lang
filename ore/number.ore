Number {
	denominator,
	numerator,
	type,

	new { num;
		.numerator = num
		.denominator = 1
	}

	./rand { max = 1; @ruby }

	clamp { min, max; @ruby }
	to_s {; @ruby }
	abs {; @ruby }
	floor {; @ruby }
	ceil {; @ruby }
	round {; @ruby }
	sqrt {; @ruby }
	even? {; @ruby }
	odd? {; @ruby }
	to_i {; @ruby }
	to_f {; @ruby }
}
