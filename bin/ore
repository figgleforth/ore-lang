#!/usr/bin/env ruby

require_relative '../src/ore'

INSTRUCTIONS = <<~INST
    Usage:
        bundle exec bin/ore <file>          Execute file and keep running until interrupt
        bundle exec bin/ore [command]       Run command

    COMMANDS:
        run <file>            Execute file and keep running until interrupt
        check <file>          Run basic type check on file

        repl                  Enter repl mode, type code press enter

        interp <code>         Execute code string
        interpf <file>        Execute file

        parse <code>          Show AST for code
        parsef <file>         Show AST for file

        lex <code>            Show lexer tokens for code
        lexf <file>           Show lexer tokens for file

        -v | --version        Show version number
        -h | --help           Show help instructions

    EXAMPLES:
        ore examples/hello.ore
        ore lex "x = 5 + 3"
        ore parsef examples/hello.ore
        ore interp "4815"
INST

if ARGV.empty?
	puts INSTRUCTIONS
	exit 1
end

begin
	case ARGV[0]
	when '-v', '--version'
		puts "Ore #{Ore::VERSION}"
		exit 0
	when '-h', '--help'
		puts INSTRUCTIONS
		exit 0
	when 'repl'
		Ore::REPL.new.run
	when 'check'
		Ore.type_check ARGV[1]
	when 'lex'
		pp Ore.lex ARGV[1]
	when 'parse'
		pp Ore.parse ARGV[1]
	when 'interp'
		pp Ore.interp ARGV[1]
	when 'lexf'
		pp Ore.lex_file ARGV[1]
	when 'parsef'
		pp Ore.parse_file ARGV[1]
	when 'interpf'
		pp Ore.interp_file ARGV[1]
	when 'interp-nostd'
		pp Ore.interp ARGV[1], load_standard_library: false
	when 'interpf-nostd'
		pp Ore.interp_file ARGV[1], load_standard_library: false
	when 'run'
		pp Ore.interp_file ARGV[1]
	else
		if ARGV[0]
			pp Ore.interp_file ARGV[0]
		else
			puts "Error: No file specified.\n#{INSTRUCTIONS}"
			exit 1
		end
	end
rescue Errno::ENOENT => e
	$stderr.puts "Could not find file `#{ARGV[0]}`\n\n#{e.full_message}"
	exit 1

rescue Ore::Error => e
	$stderr.puts e.message
	exit 1
end
